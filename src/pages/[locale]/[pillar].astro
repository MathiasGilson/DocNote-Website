---
import Layout from '../../layouts/Layout.astro';
import { locales, isValidLocale, getLocalizedPath, type Locale } from '../../utils/i18n';
import {
  pillarSlugs,
  pillars,
  pillarNavLabel,
  type PillarSlug,
} from '../../content/pillars';
import { absoluteUrl, buildBreadcrumbLd } from '../../utils/seo';

export function getStaticPaths() {
  return locales.flatMap((locale) =>
    pillarSlugs.map((pillar) => ({
      params: { locale, pillar },
    }))
  );
}

const { locale, pillar } = Astro.params;
if (!isValidLocale(locale) || !pillarSlugs.includes(pillar as PillarSlug)) {
  return Astro.redirect('/en/');
}

const lang = locale as Locale;
const slug = pillar as PillarSlug;
const p = pillars[slug][lang];
const homeLabel = lang === 'fr' ? 'Accueil' : lang === 'de' ? 'Start' : 'Home';

const breadcrumbLd = buildBreadcrumbLd([
  { name: 'DocNote', url: absoluteUrl(`/${lang}/`) },
  { name: p.title, url: absoluteUrl(`/${lang}/${slug}/`) },
]);

const primaryHref =
  slug === 'clinical-compliance'
    ? getLocalizedPath('/privacy', lang)
    : slug === 'hospital-documentation'
      ? getLocalizedPath('/contact', lang)
      : getLocalizedPath('/tutorial', lang);

const secondaryHref =
  slug === 'clinical-compliance'
    ? getLocalizedPath('/contact', lang)
    : slug === 'hospital-documentation'
      ? getLocalizedPath('/tutorial', lang)
      : getLocalizedPath('/pricing', lang);
---

<Layout title={p.title} description={p.description} jsonLd={breadcrumbLd}>
  <article class="pt-32 pb-20 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-gray-500 mb-8" aria-label="Breadcrumb">
        <ol class="flex flex-wrap items-center gap-2">
          <li>
            <a href={getLocalizedPath('/', lang)} class="hover:text-gray-900 transition-colors">{homeLabel}</a>
          </li>
          <li aria-hidden="true">/</li>
          <li class="text-gray-900 font-medium">{p.title}</li>
        </ol>
      </nav>

      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-semibold text-gray-900 tracking-tight leading-tight">
        {p.h1}
      </h1>
      <p class="mt-5 text-lg text-gray-600 leading-relaxed">{p.intro}</p>

      <div class="mt-8 flex flex-col sm:flex-row gap-3">
        <a
          href={primaryHref}
          class="inline-flex items-center justify-center px-6 py-3 text-sm font-medium text-white bg-gradient-to-r from-violet-600 to-indigo-600 rounded-full hover:from-violet-700 hover:to-indigo-700 transition-all"
        >
          {p.ctaPrimary}
        </a>
        <a
          href={secondaryHref}
          class="inline-flex items-center justify-center px-6 py-3 text-sm font-medium text-gray-700 bg-gray-100 rounded-full hover:bg-gray-200 transition-all"
        >
          {p.ctaSecondary}
        </a>
      </div>

      <div class="mt-14 space-y-10">
        {p.sections.map((section) => (
          <section>
            <h2 class="text-xl font-semibold text-gray-900 tracking-tight">{section.heading}</h2>
            <p class="mt-3 text-base text-gray-600 leading-relaxed">{section.body}</p>
          </section>
        ))}
      </div>

      <aside class="mt-16 pt-10 border-t border-gray-200">
        <h2 class="text-sm font-semibold uppercase tracking-wider text-violet-600 mb-4">{p.relatedLabel}</h2>
        <ul class="space-y-2">
          {pillarSlugs
            .filter((s) => s !== slug)
            .map((s) => (
              <li>
                <a
                  href={getLocalizedPath(`/${s}`, lang)}
                  class="text-base text-gray-800 hover:text-violet-700 transition-colors underline-offset-2 hover:underline"
                >
                  {pillarNavLabel[lang][s]}
                </a>
              </li>
            ))}
          <li>
            <a
              href={getLocalizedPath('/pricing', lang)}
              class="text-base text-gray-800 hover:text-violet-700 transition-colors underline-offset-2 hover:underline"
            >
              {lang === 'fr' ? 'Tarifs' : lang === 'de' ? 'Preise' : 'Pricing'}
            </a>
          </li>
          <li>
            <a
              href={getLocalizedPath('/blog', lang)}
              class="text-base text-gray-800 hover:text-violet-700 transition-colors underline-offset-2 hover:underline"
            >
              {lang === 'fr' ? 'Actualités' : lang === 'de' ? 'Neuigkeiten' : 'News & insights'}
            </a>
          </li>
        </ul>
      </aside>
    </div>
  </article>
</Layout>
