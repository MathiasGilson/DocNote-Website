<script define:vars={{ SHEETS_URL, strings: t, submitLabel: t.submit, submittingLabel: t.submitting, cvChosenLabel: t.cvChosen }}>
  const form = document.getElementById('careers-form');
  const errorEl = document.getElementById('form-error');
  const successEl = document.getElementById('form-success');
  const submitBtn = document.getElementById('submit-btn');
  const cvInput = document.getElementById('cv-file');
  const cvNameEl = document.getElementById('cv-file-name');

  const MAX_CV_BYTES = 5 * 1024 * 1024;
  const ALLOWED_EXT = ['.pdf', '.doc', '.docx'];
  const ALLOWED_MIME = [
    'application/pdf',
    'application/msword',
    'application/vnd.openxmlformats-officedocument.wordprocessingml.document',
  ];

  const showError = (msg) => {
    errorEl.textContent = msg;
    errorEl.classList.remove('hidden');
  };

  const fileToBase64 = (file) =>
    new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.onload = () => {
        const result = String(reader.result || '');
        const base64 = result.includes(',') ? result.split(',')[1] : result;
        resolve(base64);
      };
      reader.onerror = () => reject(reader.error);
      reader.readAsDataURL(file);
    });

  const isAllowedCv = (file) => {
    const name = file.name.toLowerCase();
    const extOk = ALLOWED_EXT.some((ext) => name.endsWith(ext));
    const mimeOk = !file.type || ALLOWED_MIME.includes(file.type);
    return extOk && mimeOk;
  };

  cvInput?.addEventListener('change', () => {
    const file = cvInput.files?.[0];
    if (!file) {
      cvNameEl.classList.add('hidden');
      cvNameEl.textContent = '';
      return;
    }
    cvNameEl.textContent = `${cvChosenLabel}: ${file.name}`;
    cvNameEl.classList.remove('hidden');
  });

  const computeScore = (data) => {
    const num = (v) => Number(v) || 0;
    const exp = (v) => (v === 'Expérience concrète' ? 6 : v === 'Bases / découverte' ? 3 : 0);
    const yn = (v) => (v === 'Oui' ? 5 : v === 'Un peu' ? 2 : 0);
    let score = 0;
    score += num(data.aiTools) * 2;
    score += num(data.copywriting) * 2;
    score += num(data.abTesting) * 2;
    score += num(data.dataAnalysis) * 2;
    score += num(data.healthInterest);
    score += exp(data.coldEmail);
    score += exp(data.funnelLanding);
    score += exp(data.communities);
    score += exp(data.linkedinVideo);
    score += yn(data.automationTools);
    score += yn(data.lookerStudio);
    if (data.genevaPresence === 'Oui, sur site') score += 5;
    else if (data.genevaPresence === 'Hybride / partiel') score += 3;
    if (data.frenchLevel === 'Natif / bilingue' || data.frenchLevel === 'C2') score += 5;
    else if (data.frenchLevel === 'C1') score += 3;
    else if (data.frenchLevel === 'B2') score += 1;
    return score;
  };

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorEl.classList.add('hidden');

    if (!SHEETS_URL) {
      showError(strings.errConfig);
      return;
    }

    const fd = new FormData(form);
    const data = Object.fromEntries(fd.entries());
    delete data.cvFile;

    const required = [
      'firstName', 'lastName', 'email', 'phone', 'linkedin', 'genevaPresence',
      'startDate', 'durationMonths', 'school', 'educationField', 'educationLevel',
      'frenchLevel', 'englishLevel', 'aiTools', 'automationTools', 'lookerStudio',
      'coldEmail', 'funnelLanding', 'communities', 'linkedinVideo', 'copywriting',
      'abTesting', 'dataAnalysis', 'healthInterest', 'motivation', 'campaignExample',
      'whyDocNote', 'source',
    ];

    for (const key of required) {
      if (!String(data[key] || '').trim()) {
        showError(strings.errRequired);
        return;
      }
    }

    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(String(data.email))) {
      showError(strings.errEmail);
      return;
    }

    const cvFile = cvInput?.files?.[0];
    if (!cvFile) {
      showError(strings.errCvRequired);
      return;
    }
    if (!isAllowedCv(cvFile)) {
      showError(strings.errCvType);
      return;
    }
    if (cvFile.size > MAX_CV_BYTES) {
      showError(strings.errCvSize);
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = submittingLabel;

    try {
      const cvBase64 = await fileToBase64(cvFile);
      const payload = {
        ...data,
        timestamp: new Date().toISOString(),
        score: computeScore(data),
        position: 'Stage Digital Marketing',
        cvFileName: cvFile.name,
        cvMimeType: cvFile.type || 'application/octet-stream',
        cvBase64,
      };

      await fetch(SHEETS_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'text/plain;charset=utf-8' },
        body: JSON.stringify(payload),
      });
      form.classList.add('hidden');
      successEl.classList.remove('hidden');
      successEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
    } catch {
      showError(strings.errNetwork);
      submitBtn.disabled = false;
      submitBtn.textContent = submitLabel;
    }
  });
</script>
