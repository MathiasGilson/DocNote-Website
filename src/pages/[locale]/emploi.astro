---

<Layout title={t.metaTitle} description={t.pageSub}>
  <section class="pt-28 pb-8 bg-gradient-to-b from-violet-50 via-white to-white">
    <div class="max-w-3xl mx-auto px-6 sm:px-8">
      <p class="text-sm font-semibold uppercase tracking-wider text-violet-600 mb-3">{t.openRoles}</p>
      <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 mb-4">{t.pageTitle}</h1>
      <p class="text-lg text-gray-600 leading-relaxed">{t.pageSub}</p>
    </div>
  </section>

  <section class="pb-12">
    <div class="max-w-3xl mx-auto px-6 sm:px-8">
      <article class="border-t border-gray-200 pt-10">
        <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">{t.jobTitle}</h2>
        <div class="flex flex-wrap gap-x-6 gap-y-2 text-sm text-gray-600 mb-8">
          <span>{t.location}</span>
          <span class="hidden sm:inline text-gray-300">|</span>
          <span>{t.type}</span>
        </div>
        <a
          href="#apply"
          class="inline-flex items-center justify-center px-6 py-3 rounded-lg bg-[#7951fb] text-white font-semibold hover:bg-[#5b3fd4] transition-colors"
        >
          {t.applyCta}
        </a>

        <div class="mt-12 space-y-10 text-gray-700 leading-relaxed">
          <div>
            <h3 class="text-lg font-bold text-gray-900 mb-3">{t.aboutTitle}</h3>
            <p class="whitespace-pre-line">{t.aboutBody}</p>
          </div>
          <div>
            <h3 class="text-lg font-bold text-gray-900 mb-3">{t.contextTitle}</h3>
            <p>{t.contextBody}</p>
          </div>
          <div>
            <h3 class="text-lg font-bold text-gray-900 mb-3">{t.missionsTitle}</h3>
            <ul class="list-disc pl-5 space-y-2">
              {t.missions.map((item) => <li>{item}</li>)}
            </ul>
          </div>
          <div>
            <h3 class="text-lg font-bold text-gray-900 mb-3">{t.profileTitle}</h3>
            <ul class="list-disc pl-5 space-y-2">
              {t.profile.map((item) => <li>{item}</li>)}
            </ul>
          </div>
          <div>
            <h3 class="text-lg font-bold text-gray-900 mb-3">{t.conditionsTitle}</h3>
            <ul class="list-disc pl-5 space-y-2">
              {t.conditions.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        </div>
      </article>
    </div>
  </section>

  <section id="apply" class="py-16 bg-gradient-to-b from-gray-50 to-white border-t border-gray-100">
    <div class="max-w-3xl mx-auto px-6 sm:px-8">
      <h2 class="text-3xl font-bold text-gray-900 mb-2">{t.formTitle}</h2>
      <p class="text-gray-600 mb-10">{t.formSub}</p>

      <div id="form-success" class="hidden rounded-xl bg-emerald-50 border border-emerald-200 p-8 text-center">
        <h3 class="text-xl font-bold text-emerald-900 mb-2">{t.successTitle}</h3>
        <p class="text-emerald-800">{t.successBody}</p>
      </div>

      <form id="careers-form" class="space-y-10" novalidate>
        <fieldset class="space-y-4">
          <legend class="text-sm font-semibold uppercase tracking-wider text-violet-600 mb-2">{t.sectionIdentity}</legend>
          <div class="grid sm:grid-cols-2 gap-4">
            <label class="block">
              <span class="text-sm font-medium text-gray-700">{t.firstName} <span class="text-violet-600">*</span></span>
