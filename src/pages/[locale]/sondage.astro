---
import Layout from '../../layouts/Layout.astro';
import specialtiesData from '../../data/survey-specialties.json';

// LinkedIn lead-funnel survey — French campaign only.
export function getStaticPaths() {
  return [{ params: { locale: 'fr' } }];
}

const SPECIALTIES = specialtiesData as { value: string; label: string }[];

// Same destinations as the header buttons.
// Absolute prod URL so the button works on staging/preview too (relative /app
// only resolves on docnote.care, not on the *.workers.dev preview domain).
const APP_WEB = 'https://docnote.care/app';
const APP_IOS = 'https://apps.apple.com/ch/app/docnote-for-doctors/id6741168204?l=fr-FR';
const APP_ANDROID = 'https://play.google.com/store/apps/details?id=app.docnote&pli=1';

// FR tutorial video (same as the Tutoriel page) — replaces the interactive recorder demo.
const TUTORIAL_VIDEO_ID = 'xnKpex2jtgs';

// Web3Forms — emails each completed lead to contact@docnote.ch.
// The access key is public by design (submit-only). Create one at
// https://web3forms.com with contact@docnote.ch, then set PUBLIC_WEB3FORMS_KEY.
const WEB3FORMS_KEY = import.meta.env.PUBLIC_WEB3FORMS_KEY || '0303b631-a251-46e1-b144-b4f83418d5ae';
---

<Layout title="Calculez votre indice de surcharge administrative">
  <div class="bg-gradient-to-b from-violet-50/60 via-white to-white min-h-screen">
    <!-- Progress bar -->
    <div id="survey-progress-wrap" class="fixed top-0 left-0 right-0 z-40 h-1 bg-violet-100 hidden">
      <div id="survey-progress" class="h-full bg-gradient-to-r from-violet-600 to-indigo-600 transition-all duration-500" style="width:0%"></div>
    </div>

    <section class="pt-28 sm:pt-32 pb-24 px-4 sm:px-6">
      <div class="max-w-2xl mx-auto">

        <!-- ============ SCREEN 1 — Intro ============ -->
        <div data-screen="1" class="survey-screen transition-all duration-500 ease-out">
          <div class="text-center">
            <div class="inline-flex items-center gap-2 bg-violet-100 text-violet-700 text-sm font-semibold px-4 py-1.5 rounded-full mb-8">
              <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-violet-500 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-violet-600"></span>
              </span>
              Sondage médecins · 2026
            </div>
            <h1 class="text-4xl sm:text-5xl font-bold leading-tight mb-6">
              <span class="text-gradient">Calculez votre indice<br class="hidden sm:block" /> de surcharge administrative</span>
            </h1>
            <p class="text-lg text-gray-600 mb-10 max-w-lg mx-auto">
              Quelques questions sur votre charge et vos conditions de travail. Découvrez où vous vous situez par rapport aux autres médecins.
            </p>
            <div class="flex flex-wrap items-center justify-center gap-6 text-gray-700 mb-10">
              <div class="flex items-center gap-2">
                <svg class="w-5 h-5 text-violet-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <span class="font-medium">2 minutes</span>
              </div>
              <div class="flex items-center gap-2">
                <svg class="w-5 h-5 text-violet-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                <span class="font-medium">100 % anonyme</span>
              </div>
            </div>
            <button type="button" data-next class="inline-flex items-center gap-2 bg-gradient-to-r from-violet-600 to-indigo-600 text-white text-lg font-semibold rounded-full px-10 py-4 shadow-lg shadow-violet-600/25 hover:shadow-xl hover:-translate-y-0.5 transition-all">
              Commencer
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            </button>
          </div>
        </div>

        <!-- ============ SCREEN 2 — Profil ============ -->
        <div data-screen="2" class="survey-screen hidden transition-all duration-500 ease-out">
          <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-2">Votre profil</h2>
          <p class="text-gray-500 mb-8">Toujours 100 % anonyme.</p>

          <div class="space-y-7">
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-2">Spécialité <span class="text-violet-500">*</span></label>
              <select data-answer="specialty" data-required class="field">
                <option value="">Sélectionnez votre spécialité…</option>
              </select>
            </div>

            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-2">Âge <span class="text-violet-500">*</span></label>
              <input type="number" min="20" max="99" inputmode="numeric" data-answer="age" data-required placeholder="Ex. 42" class="field" />
            </div>

            <div>
              <span class="block text-sm font-semibold text-gray-700 mb-2">Genre <span class="text-violet-500">*</span></span>
              <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 rounded-xl" data-group="gender" data-required>
                <button type="button" data-value="homme" class="opt">Homme</button>
                <button type="button" data-value="femme" class="opt">Femme</button>
                <button type="button" data-value="autre" class="opt">Je ne souhaite pas préciser / autre</button>
              </div>
            </div>

            <div>
              <span class="block text-sm font-semibold text-gray-700 mb-2">Poste actuel <span class="text-violet-500">*</span></span>
              <div class="grid grid-cols-2 gap-3 rounded-xl" data-group="position" data-required>
                <button type="button" data-value="interne" class="opt">Interne</button>
                <button type="button" data-value="chef_clinique" class="opt">Chef de clinique</button>
                <button type="button" data-value="adjoint" class="opt">Adjoint</button>
                <button type="button" data-value="chef_service" class="opt">Chef de service</button>
              </div>
            </div>

            <div>
              <span class="block text-sm font-semibold text-gray-700 mb-2">Type d'établissement <span class="text-violet-500">*</span></span>
              <div class="grid grid-cols-2 gap-3 rounded-xl" data-group="facility" data-required>
                <button type="button" data-value="hopital_universitaire" class="opt">Hôpital universitaire</button>
                <button type="button" data-value="hopital_peripherique" class="opt">Hôpital périphérique</button>
                <button type="button" data-value="prive_clinique" class="opt">Hôpital privé / clinique</button>
                <button type="button" data-value="cabinet" class="opt">Cabinet</button>
              </div>
            </div>
          </div>

          <p data-error class="text-sm text-red-500 mt-6 hidden">Merci de répondre à toutes les questions pour continuer.</p>
          <div class="flex items-center justify-between mt-8">
            <button type="button" data-back class="btn-back">Retour</button>
            <button type="button" data-next class="btn-next">Continuer</button>
          </div>
        </div>

        <!-- ============ SCREEN 3 — Charge de travail ============ -->
        <div data-screen="3" class="survey-screen hidden transition-all duration-500 ease-out">
          <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-8">Votre charge administrative</h2>

          <div class="space-y-9">
            <div>
              <span class="block text-sm font-semibold text-gray-700 mb-3">Quelle est votre méthode habituelle pour rédiger vos rapports de consultation ? <span class="text-violet-500">*</span></span>
              <div class="space-y-3 rounded-xl" data-group="method" data-required>
                <button type="button" data-value="papier_puis_ordi" class="opt opt-wide">Prise de note papier puis saisie à l'ordinateur après la consultation</button>
                <button type="button" data-value="ordi_pendant" class="opt opt-wide">Prise de note directement sur ordinateur pendant la consultation</button>
                <button type="button" data-value="note_puis_dictee" class="opt opt-wide">Prise de note puis dictée (Dragon / dictaphone)</button>
                <button type="button" data-value="dictee_sans_note" class="opt opt-wide">Dictée (Dragon / dictaphone) sans prise de note</button>
                <button type="button" data-value="autre" class="opt opt-wide">Autre</button>
              </div>
              <input type="text" data-answer="methodOther" placeholder="Précisez (optionnel)…" class="mt-3 w-full rounded-xl border border-gray-200 bg-white px-4 py-2.5 text-sm text-gray-900 focus:border-violet-500 focus:ring-2 focus:ring-violet-200 outline-none transition hidden" data-other-for="method" />
            </div>

            <div>
              <span class="block text-sm font-semibold text-gray-700 mb-4">Combien de temps consacrez-vous, pour chaque consultation, à la rédaction du rapport administratif ?</span>
              <div class="px-1">
                <input type="range" min="0" max="45" value="12" step="1" data-answer="time" class="survey-range" />
                <div class="flex justify-between text-xs text-gray-400 mt-2">
                  <span>0 min</span>
                  <span id="time-val" class="font-bold text-violet-600 text-base">12 min</span>
                  <span>45 min</span>
                </div>
              </div>
            </div>

            <div>
              <span class="block text-sm font-semibold text-gray-700 mb-4">À quel point la gestion administrative impacte-t-elle votre travail (stress, charge mentale) ?</span>
              <div class="px-1">
                <input type="range" min="0" max="10" value="5" data-answer="impact" class="survey-range" />
                <div class="flex justify-between text-xs text-gray-400 mt-2">
                  <span>Aucun impact</span>
                  <span id="impact-val" class="font-bold text-violet-600 text-base">5 / 10</span>
                  <span>Impact majeur</span>
                </div>
              </div>
            </div>

            <div>
              <span class="block text-sm font-semibold text-gray-700 mb-3">Heures supplémentaires liées à l'administratif (par semaine) <span class="text-violet-500">*</span></span>
              <div class="grid grid-cols-2 sm:grid-cols-5 gap-3 rounded-xl" data-group="overtime" data-required>
                <button type="button" data-value="0" class="opt">0 h</button>
                <button type="button" data-value="1" class="opt">&lt; 2 h</button>
                <button type="button" data-value="2" class="opt">2–5 h</button>
                <button type="button" data-value="3" class="opt">5–10 h</button>
                <button type="button" data-value="4" class="opt">&gt; 10 h</button>
              </div>
            </div>
          </div>

          <p data-error class="text-sm text-red-500 mt-6 hidden">Merci de répondre à toutes les questions pour continuer.</p>
          <div class="flex items-center justify-between mt-8">
            <button type="button" data-back class="btn-back">Retour</button>
            <button type="button" data-next class="btn-next">Voir mes résultats</button>
          </div>
        </div>

        <!-- ============ SCREEN 4 — Coordonnées ============ -->
        <div data-screen="4" class="survey-screen hidden transition-all duration-500 ease-out">
          <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-2">Où envoyer vos résultats ?</h2>
          <p class="text-gray-500 mb-8">On vous prépare votre indice personnalisé et une comparaison avec les autres médecins.</p>

          <div class="space-y-5">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2">Prénom <span class="text-violet-500">*</span></label>
                <input type="text" data-answer="firstName" data-required autocomplete="given-name" class="field" />
              </div>
              <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2">Nom <span class="text-violet-500">*</span></label>
                <input type="text" data-answer="lastName" data-required autocomplete="family-name" class="field" />
              </div>
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-2">Adresse e-mail <span class="text-violet-500">*</span></label>
              <input type="email" data-answer="email" data-required autocomplete="email" placeholder="vous@exemple.com" class="field" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-2">Numéro de téléphone <span class="text-violet-500">*</span></label>
              <div class="flex gap-3">
                <select data-answer="phoneCode" class="w-28 rounded-xl border border-gray-200 bg-white px-3 py-3 text-gray-900 focus:border-violet-500 focus:ring-2 focus:ring-violet-200 outline-none transition">
                  <option value="+41">🇨🇭 +41</option>
                  <option value="+33">🇫🇷 +33</option>
                  <option value="+32">🇧🇪 +32</option>
                  <option value="+49">🇩🇪 +49</option>
                  <option value="+352">🇱🇺 +352</option>
                  <option value="+39">🇮🇹 +39</option>
                </select>
                <input type="tel" data-answer="phone" data-required autocomplete="tel" placeholder="79 123 45 67" class="field flex-1" />
              </div>
            </div>
            <p data-error class="text-sm text-red-500 hidden">Merci de renseigner tous les champs, avec un e-mail et un numéro de téléphone valides.</p>
          </div>

          <p class="text-xs text-gray-400 mt-6 flex items-start gap-2">
            <svg class="w-4 h-4 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
            Vos données restent confidentielles et ne sont jamais revendues. Hébergement suisse, conforme nLPD / RGPD.
          </p>

          <div class="flex items-center justify-between mt-8">
            <button type="button" data-back class="btn-back">Retour</button>
            <button type="button" data-next class="btn-next">Découvrir mon indice</button>
          </div>
        </div>

        <!-- ============ SCREEN 5 — Résultats ============ -->
        <div data-screen="5" class="survey-screen hidden transition-all duration-500 ease-out">
          <div class="text-center mb-10">
            <p class="text-sm font-semibold text-violet-600 uppercase tracking-wider mb-2">Votre indice de surcharge administrative</p>
            <div class="text-7xl font-bold text-gradient mb-2"><span id="score-value">0</span><span class="text-3xl text-gray-400">/100</span></div>
            <p id="score-label" class="text-lg text-gray-700 font-medium"></p>
          </div>

          <!-- Gaussian: surcharge positioning -->
          <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 mb-6">
            <h3 class="text-base font-semibold text-gray-900 mb-1">Où vous situez-vous ?</h3>
            <p id="percentile-text" class="text-sm text-gray-500 mb-4"></p>
            <div id="gauss-chart" class="w-full"></div>
          </div>

          <!-- Gaussian: time per consultation -->
          <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 mb-10">
            <h3 class="text-base font-semibold text-gray-900 mb-1">Temps de rédaction par consultation</h3>
            <p id="time-caption" class="text-sm text-gray-500 mb-4"></p>
            <div id="time-chart" class="w-full"></div>
          </div>

          <!-- ===== DocNote demo (tutorial video) ===== -->
          <div class="rounded-3xl bg-slate-50 border border-slate-100 p-6 sm:p-9 shadow-sm">
            <div class="text-center mb-7">
              <h3 class="text-2xl font-bold text-slate-900 mb-2">Et si ce rapport s'écrivait tout seul ?</h3>
              <p class="text-slate-600">Découvrez en vidéo comment DocNote rédige un rapport complet au format <span id="demo-spec-label" class="font-semibold text-blue-600">de votre spécialité</span>, à partir d'une simple dictée vocale.</p>
            </div>

            <!-- Responsive 16:9 tutorial video — click to play -->
            <div class="mx-auto overflow-hidden rounded-2xl shadow-lg bg-slate-900" style="max-width:640px;">
              <div class="relative w-full" style="aspect-ratio:16/9;">
                <iframe
                  class="absolute inset-0 h-full w-full"
                  src={`https://www.youtube.com/embed/${TUTORIAL_VIDEO_ID}`}
                  title="DocNote — démonstration"
                  frameborder="0"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                  allowfullscreen
                  loading="lazy"
                ></iframe>
              </div>
            </div>

            <!-- Onboarding CTA -->
            <div id="onboarding-cta" class="mt-8 text-center">
              <p class="text-gray-700 mb-1 font-medium">Votre compte est déjà pré-configuré</p>
              <p class="text-gray-500 text-sm mb-5">Langue, spécialité et téléphone sont pré-remplis. Démarrez en un clic 👇</p>
              <div class="flex flex-col sm:flex-row gap-3 justify-center">
                <a id="cta-web" href={APP_WEB} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 bg-gradient-to-r from-violet-600 to-indigo-600 text-white font-semibold rounded-full px-7 py-3.5 shadow-lg shadow-violet-600/25 hover:shadow-xl hover:-translate-y-0.5 transition-all">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.6 9h16.8M3.6 15h16.8M12 3a15 15 0 010 18M12 3a15 15 0 000 18"/></svg>
                  Lancer l'application web
                </a>
                <a id="cta-ios" href={APP_IOS} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 bg-gray-100 text-gray-700 font-semibold rounded-full px-7 py-3.5 hover:bg-gray-200 transition-all">App Store</a>
                <a id="cta-android" href={APP_ANDROID} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 bg-gray-100 text-gray-700 font-semibold rounded-full px-7 py-3.5 hover:bg-gray-200 transition-all">Google Play</a>
              </div>
            </div>
          </div>

        </div>

      </div>
    </section>
  </div>

  <style>
    .opt {
      @apply text-sm font-medium text-gray-700 bg-white border border-gray-200 rounded-xl px-4 py-3 text-center cursor-pointer transition-all hover:border-violet-300 hover:bg-violet-50/40;
    }
    .opt-wide { @apply text-left; }
    .opt.selected {
      @apply border-violet-600 bg-violet-50 text-violet-700 ring-1 ring-violet-600;
    }
    .field {
      @apply w-full rounded-xl border border-gray-200 bg-white px-4 py-3 text-gray-900 focus:border-violet-500 focus:ring-2 focus:ring-violet-200 outline-none transition;
    }
    .btn-next {
      @apply inline-flex items-center gap-2 bg-gradient-to-r from-violet-600 to-indigo-600 text-white font-semibold rounded-full px-8 py-3 shadow-lg shadow-violet-600/25 hover:shadow-xl hover:-translate-y-0.5 transition-all;
    }
    .btn-back {
      @apply text-gray-500 font-medium px-4 py-3 hover:text-gray-800 transition-colors;
    }
    /* Slider styling */
    .survey-range {
      @apply w-full appearance-none bg-transparent cursor-pointer;
      height: 24px;
    }
    .survey-range::-webkit-slider-runnable-track {
      height: 8px; border-radius: 9999px;
      background: linear-gradient(to right, #7c3aed, #4f46e5);
    }
    .survey-range::-moz-range-track {
      height: 8px; border-radius: 9999px;
      background: linear-gradient(to right, #7c3aed, #4f46e5);
    }
    .survey-range::-webkit-slider-thumb {
      -webkit-appearance: none; appearance: none;
      width: 24px; height: 24px; margin-top: -8px;
      border-radius: 9999px; background: #fff;
      border: 3px solid #7c3aed; box-shadow: 0 2px 6px rgba(124,58,237,.35);
      transition: transform .1s;
    }
    .survey-range::-webkit-slider-thumb:active { transform: scale(1.15); }
    .survey-range::-moz-range-thumb {
      width: 24px; height: 24px; border-radius: 9999px; background: #fff;
      border: 3px solid #7c3aed; box-shadow: 0 2px 6px rgba(124,58,237,.35);
    }
    .field-error { @apply border-red-400 ring-2 ring-red-200; }
    .group-error { @apply ring-2 ring-red-300; }
    /* Gaussian path draw-in */
    .gauss-line { stroke-dasharray: 1400; stroke-dashoffset: 1400; animation: gaussdraw 1.1s ease-out forwards; }
    @keyframes gaussdraw { to { stroke-dashoffset: 0; } }
  </style>

  <script define:vars={{ SPECIALTIES, APP_WEB, WEB3FORMS_KEY }}>
    (function () {
      // ---------------- State ----------------
      const answers = { time: 12, impact: 5, phoneCode: '+41' };
      let current = 1;
      const TOTAL = 5;

      const screens = Array.from(document.querySelectorAll('.survey-screen'));
      const progressWrap = document.getElementById('survey-progress-wrap');
      const progressBar = document.getElementById('survey-progress');
      const screenEl = (n) => document.querySelector(`[data-screen="${n}"]`);
      function ph() { return window.posthog; }

      // ---------------- Specialty dropdown ----------------
      const specSelect = document.querySelector('[data-answer="specialty"]');
      SPECIALTIES.forEach((s) => {
        const o = document.createElement('option');
        o.value = s.value; o.textContent = s.label;
        specSelect.appendChild(o);
      });
      const specLabel = (val) => (SPECIALTIES.find((s) => s.value === val) || {}).label || 'votre spécialité';

      // ---------------- Inputs ----------------
      document.querySelectorAll('[data-answer]').forEach((el) => {
        el.addEventListener('input', () => {
          answers[el.getAttribute('data-answer')] = el.value;
          el.classList.remove('field-error');
          if (el.getAttribute('data-answer') === 'impact') document.getElementById('impact-val').textContent = el.value + ' / 10';
          if (el.getAttribute('data-answer') === 'time') document.getElementById('time-val').textContent = el.value + ' min';
        });
      });

      // Single-select button groups
      document.querySelectorAll('[data-group]').forEach((group) => {
        const name = group.getAttribute('data-group');
        group.querySelectorAll('button[data-value]').forEach((btn) => {
          btn.addEventListener('click', () => {
            group.querySelectorAll('button[data-value]').forEach((b) => b.classList.remove('selected'));
            btn.classList.add('selected');
            answers[name] = btn.getAttribute('data-value');
            group.classList.remove('group-error');
            const other = document.querySelector(`[data-other-for="${name}"]`);
            if (other) other.classList.toggle('hidden', btn.getAttribute('data-value') !== 'autre');
          });
        });
      });

      // ---------------- Navigation + animation ----------------
      function show(n) {
        screens.forEach((s) => s.classList.toggle('hidden', Number(s.dataset.screen) !== n));
        current = n;
        progressWrap.classList.toggle('hidden', n === 1);
        progressBar.style.width = ((n - 1) / (TOTAL - 1)) * 100 + '%';
        const el = screenEl(n);
        el.classList.add('opacity-0', 'translate-y-3');
        requestAnimationFrame(() => requestAnimationFrame(() => el.classList.remove('opacity-0', 'translate-y-3')));
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }

      // ---------------- Validation (mandatory) ----------------
      function validate(n) {
        const scr = screenEl(n);
        let ok = true;
        scr.querySelectorAll('[data-required]').forEach((el) => {
          if (el.hasAttribute('data-group')) {
            if (!answers[el.getAttribute('data-group')]) { el.classList.add('group-error'); ok = false; }
          } else {
            const key = el.getAttribute('data-answer');
            let val = (answers[key] || '').toString().trim();
            let valid = !!val;
            if (key === 'email') valid = /.+@.+\..+/.test(val);
            if (key === 'phone') valid = val.replace(/\D/g, '').length >= 6;
            if (!valid) { el.classList.add('field-error'); ok = false; }
          }
        });
        const err = scr.querySelector('[data-error]');
        if (err) err.classList.toggle('hidden', ok);
        if (!ok) {
          const first = scr.querySelector('.field-error, .group-error');
          if (first && first.scrollIntoView) first.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
        return ok;
      }

      document.querySelectorAll('[data-next]').forEach((btn) => {
        btn.addEventListener('click', () => {
          if (!validate(current)) return;
          if (current === 1) ph()?.capture?.('survey_started');
          if (current === 4) finishSurvey();
          if (current < TOTAL) show(current + 1);
        });
      });
      document.querySelectorAll('[data-back]').forEach((btn) => {
        btn.addEventListener('click', () => { if (current > 1) show(current - 1); });
      });

      // ---------------- Scoring ----------------
      const OVERTIME_SCORE = [0, 8, 15, 20, 25];
      function computeScore() {
        const minutes = Math.min(45, Math.max(0, Number(answers.time)));
        const timeScore = (minutes / 45) * 42;
        const impactScore = (Number(answers.impact) / 10) * 33;
        const ot = OVERTIME_SCORE[Number(answers.overtime)] ?? 12;
        return Math.max(12, Math.min(100, Math.round(timeScore + impactScore + ot)));
      }

      // Normal helpers — surcharge population: mean 55, sd 16. Chosen so the
      // ">62nd percentile" floor maps to a displayed score around 60/100
      // (high and coherent), while heavier answers climb toward 85-95.
      const S_MEAN = 55, S_SD = 16;
      function erf(x) {
        const t = 1 / (1 + 0.3275911 * Math.abs(x));
        const y = 1 - (((((1.061405429 * t - 1.453152027) * t) + 1.421413741) * t - 0.284496736) * t + 0.254829592) * t * Math.exp(-x * x);
        return x >= 0 ? y : -y;
      }
      const cdf = (x, m, s) => 0.5 * (1 + erf((x - m) / (s * Math.SQRT2)));
      const pdf = (x, m, s) => Math.exp(-((x - m) ** 2) / (2 * s * s)) / (s * Math.sqrt(2 * Math.PI));
      // Inverse normal (Acklam) -> z-score for probability p
      function probit(p) {
        const a = [-3.969683028665376e1, 2.209460984245205e2, -2.759285104469687e2, 1.38357751867269e2, -3.066479806614716e1, 2.506628277459239];
        const b = [-5.447609879822406e1, 1.615858368580409e2, -1.556989798598866e2, 6.680131188771972e1, -1.328068155288572e1];
        const c = [-7.784894002430293e-3, -3.223964580411365e-1, -2.400758277161838, -2.549732539343734, 4.374664141464968, 2.938163982698783];
        const d = [7.784695709041462e-3, 3.224671290700398e-1, 2.445134137142996, 3.754408661907416];
        const pl = 0.02425, ph2 = 1 - pl; let q, r;
        if (p < pl) { q = Math.sqrt(-2 * Math.log(p)); return (((((c[0]*q+c[1])*q+c[2])*q+c[3])*q+c[4])*q+c[5]) / ((((d[0]*q+d[1])*q+d[2])*q+d[3])*q+1); }
        if (p <= ph2) { q = p - 0.5; r = q*q; return (((((a[0]*r+a[1])*r+a[2])*r+a[3])*r+a[4])*r+a[5])*q / (((((b[0]*r+b[1])*r+b[2])*r+b[3])*r+b[4])*r+1); }
        q = Math.sqrt(-2 * Math.log(1 - p)); return -(((((c[0]*q+c[1])*q+c[2])*q+c[3])*q+c[4])*q+c[5]) / ((((d[0]*q+d[1])*q+d[2])*q+d[3])*q+1);
      }

      // ---------------- Gaussian chart (generic) ----------------
      function drawGauss(targetId, opts) {
        const { mean, sd, xMin, xMax, userX, userLabel, leftLabel, rightLabel } = opts;
        const W = 560, H = 200, padX = 20, padB = 28, padT = 22;
        const x = (v) => padX + ((v - xMin) / (xMax - xMin)) * (W - 2 * padX);
        const maxP = pdf(mean, mean, sd);
        const y = (p) => H - padB - (p / maxP) * (H - padB - padT);
        let line = '', area = `M ${x(xMin)} ${H - padB} `;
        const N = 120;
        for (let i = 0; i <= N; i++) {
          const v = xMin + (i / N) * (xMax - xMin);
          const px = x(v), py = y(pdf(v, mean, sd));
          line += (i === 0 ? 'M' : 'L') + ' ' + px.toFixed(1) + ' ' + py.toFixed(1) + ' ';
          area += 'L ' + px.toFixed(1) + ' ' + py.toFixed(1) + ' ';
        }
        area += `L ${x(xMax)} ${H - padB} Z`;
        const sx = x(Math.min(xMax, Math.max(xMin, userX)));
        const lblX = Math.min(W - 52, Math.max(52, sx));
        const svg = `
          <svg viewBox="0 0 ${W} ${H}" class="w-full h-auto">
            <defs><linearGradient id="g_${targetId}" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#7c3aed" stop-opacity="0.28"/>
              <stop offset="100%" stop-color="#7c3aed" stop-opacity="0.02"/>
            </linearGradient></defs>
            <path d="${area}" fill="url(#g_${targetId})"/>
            <path d="${line}" fill="none" stroke="#a78bfa" stroke-width="2.5" class="gauss-line"/>
            <line x1="${sx}" y1="${padT - 6}" x2="${sx}" y2="${H - padB}" stroke="#4f46e5" stroke-width="2" stroke-dasharray="5 4"/>
            <circle cx="${sx}" cy="${y(pdf(userX, mean, sd))}" r="6" fill="#4f46e5" stroke="white" stroke-width="2"/>
            <rect x="${lblX - 46}" y="${padT - 20}" width="92" height="22" rx="11" fill="#4f46e5"/>
            <text x="${lblX}" y="${padT - 5}" fill="white" font-size="12" font-weight="700" text-anchor="middle">${userLabel}</text>
            <text x="${x(xMin) + 28}" y="${H - 8}" fill="#9ca3af" font-size="11" text-anchor="middle">${leftLabel}</text>
            <text x="${x(xMax) - 28}" y="${H - 8}" fill="#9ca3af" font-size="11" text-anchor="middle">${rightLabel}</text>
          </svg>`;
        document.getElementById(targetId).innerHTML = svg;
      }

      // ---------------- Finish: compute + render ----------------
      function finishSurvey() {
        const computed = computeScore();
        let pct = Math.round(cdf(computed, S_MEAN, S_SD) * 100);
        // Always position the doctor among the >60% most overloaded.
        const pctFinal = Math.max(62, Math.min(97, pct));
        let displayScore = computed;
        if (pctFinal !== pct) displayScore = Math.round(S_MEAN + S_SD * probit(pctFinal / 100));
        displayScore = Math.max(12, Math.min(100, displayScore));

        // animate big number
        const el = document.getElementById('score-value');
        let v = 0; const stepN = Math.max(1, Math.round(displayScore / 28));
        const iv = setInterval(() => { v = Math.min(displayScore, v + stepN); el.textContent = v; if (v >= displayScore) clearInterval(iv); }, 28);

        const label =
          displayScore >= 75 ? 'Surcharge administrative critique' :
          displayScore >= 60 ? 'Surcharge administrative élevée' :
          'Surcharge administrative notable';
        document.getElementById('score-label').textContent = label;
        document.getElementById('percentile-text').textContent =
          `Vous êtes plus surchargé·e que ${pctFinal} % des médecins déjà sondés.`;

        drawGauss('gauss-chart', {
          mean: S_MEAN, sd: S_SD, xMin: 0, xMax: 100, userX: displayScore,
          userLabel: `Vous · ${displayScore}`, leftLabel: 'Peu surchargés', rightLabel: 'Très surchargés',
        });

        // time gaussian (population mean 15 min, sd 9)
        const minutes = Number(answers.time);
        const timePct = Math.round(cdf(minutes, 15, 9) * 100);
        document.getElementById('time-caption').textContent =
          `Vous y consacrez ${minutes} min — plus que ${Math.max(2, Math.min(98, timePct))} % des médecins.`;
        drawGauss('time-chart', {
          mean: 15, sd: 9, xMin: 0, xMax: 45, userX: minutes,
          userLabel: `${minutes} min`, leftLabel: 'Rapide', rightLabel: 'Chronophage',
        });

        document.getElementById('demo-spec-label').textContent = specLabel(answers.specialty);
        buildOnboardingLinks();
        sendLead(displayScore, pctFinal);

        ph()?.identify?.(answers.email, {
          email: answers.email,
          name: [answers.firstName, answers.lastName].filter(Boolean).join(' '),
          phone: (answers.phoneCode || '') + ' ' + (answers.phone || ''),
          specialty: answers.specialty,
        });
        ph()?.capture?.('survey_completed', {
          score: displayScore, percentile: pctFinal, specialty: answers.specialty,
          age: answers.age, gender: answers.gender, position: answers.position,
          facility: answers.facility, method: answers.method,
          time_minutes: answers.time, overtime: answers.overtime, impact: answers.impact,
        });
      }

      // Email each completed submission to contact@docnote.ch via Web3Forms.
      const OVERTIME_LABEL = ['0 h', '< 2 h', '2–5 h', '5–10 h', '> 10 h'];
      const GENDER_LABEL = { homme: 'Homme', femme: 'Femme', autre: 'Non précisé' };
      const POSITION_LABEL = { interne: 'Interne', chef_clinique: 'Chef de clinique', adjoint: 'Adjoint', chef_service: 'Chef de service' };
      const FACILITY_LABEL = { hopital_universitaire: 'Hôpital universitaire', hopital_peripherique: 'Hôpital périphérique', prive_clinique: 'Hôpital privé / clinique', cabinet: 'Cabinet' };
      const METHOD_LABEL = { papier_puis_ordi: 'Papier puis ordinateur', ordi_pendant: 'Ordinateur pendant la consultation', note_puis_dictee: 'Note puis dictée', dictee_sans_note: 'Dictée sans note', autre: 'Autre' };

      function sendLead(score, percentile) {
        if (!WEB3FORMS_KEY || WEB3FORMS_KEY.indexOf('YOUR_') === 0) {
          console.warn('[sondage] WEB3FORMS_KEY non configurée — lead non envoyé par email.');
          return;
        }
        const fullName = [answers.firstName, answers.lastName].filter(Boolean).join(' ');
        const method = answers.method === 'autre' && answers.methodOther ? `Autre — ${answers.methodOther}` : (METHOD_LABEL[answers.method] || answers.method || '');
        const payload = {
          access_key: WEB3FORMS_KEY,
          subject: `🩺 Nouveau lead sondage — ${fullName || 'Médecin'} (${specLabel(answers.specialty)})`,
          from_name: 'Sondage surcharge administrative — DocNote',
          'Nom complet': fullName,
          'E-mail': answers.email || '',
          'Téléphone': ((answers.phoneCode || '') + ' ' + (answers.phone || '')).trim(),
          'Spécialité': specLabel(answers.specialty),
          'Âge': answers.age || '',
          'Genre': GENDER_LABEL[answers.gender] || answers.gender || '',
          'Poste': POSITION_LABEL[answers.position] || answers.position || '',
          'Établissement': FACILITY_LABEL[answers.facility] || answers.facility || '',
          'Méthode de rédaction': method,
          'Temps par consultation (min)': answers.time,
          'Heures supplémentaires / semaine': OVERTIME_LABEL[Number(answers.overtime)] || '',
          'Impact administratif (/10)': answers.impact,
          'Indice de surcharge (/100)': score,
          'Percentile': `${percentile} %`,
        };
        try {
          fetch('https://api.web3forms.com/submit', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
            body: JSON.stringify(payload),
          }).catch(() => {});
        } catch (_) {}
      }

      function buildOnboardingLinks() {
        const phoneFull = ((answers.phoneCode || '') + (answers.phone || '')).replace(/\s+/g, '');
        const q = new URLSearchParams({ lang: 'fr', specialty: answers.specialty || '', dpi: 'none', phone: phoneFull, utm_source: 'sondage_linkedin' });
        // Trailing slash is required: /app?query 404s, /app/?query works.
        document.getElementById('cta-web').setAttribute('href', `${APP_WEB}/?${q.toString()}`);
      }

      // init
      show(1);
    })();
  </script>
</Layout>
