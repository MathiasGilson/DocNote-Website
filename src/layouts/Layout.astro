---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import { getLocaleFromUrl, locales, type Locale } from '../utils/i18n';
import { getEntry } from 'astro:content';
import {
  absoluteUrl,
  formatPageTitle,
  getDefaultAlternates,
  getOgLocale,
  OG_IMAGE,
  OG_IMAGE_HEIGHT,
  OG_IMAGE_WIDTH,
  SITE_URL,
  withTrailingSlash,
} from '../utils/seo';

interface Props {
  title: string;
  description?: string;
  alternates?: Partial<Record<Locale, string>>;
  ogType?: 'website' | 'article';
  ogImage?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const DEFAULT_DESCRIPTIONS: Record<Locale, string> = {
  en: 'DocNote is the AI-powered medical scribe and clinical documentation assistant for doctors, surgeons and hospitals in Switzerland and Europe. Generate consultation notes, discharge letters, operative reports and ward-round notes from voice in seconds. Swiss-hosted, FADP, GDPR, HIPAA and ISO 27001 compliant.',
  fr: "DocNote est l'assistant IA de documentation médicale pour les médecins, chirurgiens et hôpitaux en Suisse, en France et en Europe. Générez en quelques secondes vos notes de consultation, lettres de sortie, comptes rendus opératoires et notes de visite à partir de la voix. Hébergé en Suisse, conforme nLPD, RGPD, HIPAA et ISO 27001.",
  de: 'DocNote ist der KI-gestützte medizinische Schreibassistent für Ärztinnen, Ärzte, Chirurginnen, Chirurgen und Spitäler in der Schweiz, in Deutschland, Österreich und Europa. Konsultationsnotizen, Austrittsberichte, OP-Berichte und Visitennotizen in Sekunden aus der Sprache. In der Schweiz gehostet, DSG-, DSGVO-, HIPAA- und ISO-27001-konform.',
};

const locale = getLocaleFromUrl(Astro.url);
const {
  title,
  description = DEFAULT_DESCRIPTIONS[locale],
  alternates: alternatesProp,
  ogType = 'website',
  ogImage = OG_IMAGE,
  jsonLd,
} = Astro.props;
const t = await getEntry('pages', locale);

const pageTitle = formatPageTitle(title);
const canonicalUrl = absoluteUrl(withTrailingSlash(Astro.url.pathname));
const alternateUrls = { ...getDefaultAlternates(Astro.url.pathname), ...alternatesProp };
const ogLocale = getOgLocale(locale);
const extraJsonLd = jsonLd
  ? Array.isArray(jsonLd)
    ? jsonLd
    : [jsonLd]
  : [];

// Site-wide Organization, WebSite, and SoftwareApplication structured data.
// Helps Google rich results AND gives LLMs (ChatGPT, Claude, Perplexity, Gemini)
// a clean entity graph to cite when users ask "best AI medical scribe".
const organizationLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'DocNote',
  legalName: 'Gilson GmbH',
  url: SITE_URL,
  logo: `${SITE_URL}/images/logo.png`,
  description: DEFAULT_DESCRIPTIONS[locale],
  foundingDate: '2024',
  email: 'contact@docnote.care',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Baarermattstrasse 8B',
    postalCode: '6340',
    addressLocality: 'Baar',
    addressCountry: 'CH',
  },
  contactPoint: [
    {
      '@type': 'ContactPoint',
      contactType: 'sales',
      name: 'Dr. Vincent Tan',
      email: 'vincent.tan@docnote.ch',
      telephone: '+41 78 639 83 76',
      areaServed: 'CH',
      availableLanguage: ['French', 'German', 'English'],
    },
    {
      '@type': 'ContactPoint',
      contactType: 'sales',
      name: 'Dr. Alice Gilson',
      email: 'alice.gilson@docnote.ch',
      telephone: '+33 6 95 28 84 85',
      areaServed: 'FR',
      availableLanguage: ['French', 'English'],
    },
  ],
  sameAs: [
    'https://www.linkedin.com/company/docnote-for-doctors',
    'https://www.linkedin.com/company/107244351',
  ],
};

const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'DocNote',
  url: SITE_URL,
  inLanguage: ['en', 'fr', 'de'],
  publisher: { '@type': 'Organization', name: 'DocNote' },
};

const softwareApplicationLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'DocNote',
  applicationCategory: 'HealthApplication',
  applicationSubCategory: 'AI Medical Scribe',
  operatingSystem: 'iOS, Android, Web',
  description: DEFAULT_DESCRIPTIONS[locale],
  url: SITE_URL,
  image: `${SITE_URL}/images/logo.png`,
  softwareVersion: '2026',
  inLanguage: ['en', 'fr', 'de', 'it'],
  audience: {
    '@type': 'MedicalAudience',
    audienceType: 'Physicians, surgeons, hospitals, medical practices',
  },
  featureList: [
    'AI-powered medical voice transcription',
    'Automatic SOAP note generation',
    'Discharge letter generation',
    'Operative report (OR report) generation',
    'Ward-round notes',
    'Swiss DRG and PMSI medical coding suggestions',
    'TARDOC-compliant clinical examination descriptions',
    'EHR integration with Mediway and SOKLE',
    'Custom Word template support (drag and drop)',
    'Multi-caregiver day-hospital file sharing',
    'End-to-end encryption (AES-256, TLS 1.3)',
    'Swiss-only data hosting',
    'FADP, GDPR, HIPAA, ISO 27001 compliance',
    'Mobile and desktop real-time sync',
    'Multilingual support (French, German, Italian, English, 20+ languages)',
  ],
  offers: [
    {
      '@type': 'Offer',
      name: 'Professional (monthly)',
      price: '109',
      priceCurrency: 'CHF',
      priceSpecification: {
        '@type': 'UnitPriceSpecification',
        price: '109',
        priceCurrency: 'CHF',
        unitText: 'MONTH',
      },
      availability: 'https://schema.org/InStock',
      url: absoluteUrl(`/${locale}/pricing`),
    },
    {
      '@type': 'Offer',
      name: 'Professional (yearly billing)',
      price: '99',
      priceCurrency: 'CHF',
      priceSpecification: {
        '@type': 'UnitPriceSpecification',
        price: '99',
        priceCurrency: 'CHF',
        unitText: 'MONTH',
      },
      availability: 'https://schema.org/InStock',
      url: absoluteUrl(`/${locale}/pricing`),
    },
  ],
  provider: { '@type': 'Organization', name: 'DocNote', legalName: 'Gilson GmbH' },
};
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow,max-snippet:-1,max-image-preview:large,max-video-preview:-1" />
    <meta name="author" content="DocNote — Gilson GmbH" />
    {import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION && (
      <meta name="google-site-verification" content={import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION} />
    )}
    <meta name="keywords" content="AI medical scribe, scribe IA médical, KI medizinischer Schreibassistent, medical documentation AI, documentation médicale IA, DocNote, ambient AI scribe, clinical documentation, Swiss DRG, TARDOC, PMSI, FADP, nLPD, GDPR, HIPAA, ISO 27001, Mediway, SOKLE, discharge letter, lettre de sortie, Austrittsbericht, operative report, compte rendu opératoire, OP-Bericht, ward round notes, doctor productivity, physician burnout, ambient listening" />
    <link rel="canonical" href={canonicalUrl} />
    {locales.map((code) => (
      alternateUrls[code] && <link rel="alternate" hreflang={code} href={alternateUrls[code]} />
    ))}
    <link rel="alternate" hreflang="x-default" href={alternateUrls.en || absoluteUrl('/en/')} />

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="DocNote" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content={String(OG_IMAGE_WIDTH)} />
    <meta property="og:image:height" content={String(OG_IMAGE_HEIGHT)} />
    <meta property="og:locale" content={ogLocale} />
    {locales
      .filter((code) => code !== locale)
      .map((code) => (
        <meta property="og:locale:alternate" content={getOgLocale(code)} />
      ))}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/png" href="/images/favicon.png" />
    <title>{pageTitle}</title>

    <script is:inline type="application/ld+json" set:html={JSON.stringify(organizationLd)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteLd)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(softwareApplicationLd)} />
    {extraJsonLd.map((item) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}

    <script is:inline>
      !function(t,e){var o,n,p,r;e.__SV||(window.posthog && window.posthog.__loaded)||(window.posthog=e,e._i=[],e.init=function(i,s,a){function g(t,e){var o=e.split(".");2==o.length&&(t=t[o[0]],e=o[1]),t[e]=function(){t.push([e].concat(Array.prototype.slice.call(arguments,0)))}}(p=t.createElement("script")).type="text/javascript",p.crossOrigin="anonymous",p.async=!0,p.src=s.api_host.replace(".i.posthog.com","-assets.i.posthog.com")+"/static/array.js",(r=t.getElementsByTagName("script")[0]).parentNode.insertBefore(p,r);var u=e;for(void 0!==a?u=e[a]=[]:a="posthog",u.people=u.people||[],u.toString=function(t){var e="posthog";return"posthog"!==a&&(e+="."+a),t||(e+=" (stub)"),e},u.people.toString=function(){return u.toString(1)+".people (stub)"},o="Ir init Br Zr Ci jr $r Lr capture calculateEventProperties Yr register register_once register_for_session unregister unregister_for_session Jr getFeatureFlag getFeatureFlagPayload getFeatureFlagResult isFeatureEnabled reloadFeatureFlags updateFlags updateEarlyAccessFeatureEnrollment getEarlyAccessFeatures on onFeatureFlags onSurveysLoaded onSessionId getSurveys getActiveMatchingSurveys renderSurvey displaySurvey cancelPendingSurvey canRenderSurvey canRenderSurveyAsync Kr identify setPersonProperties group resetGroups setPersonPropertiesForFlags resetPersonPropertiesForFlags setGroupPropertiesForFlags resetGroupPropertiesForFlags reset setIdentity clearIdentity get_distinct_id getGroups get_session_id get_session_replay_url alias set_config startSessionRecording stopSessionRecording sessionRecordingStarted captureException captureLog startExceptionAutocapture stopExceptionAutocapture loadToolbar get_property getSessionProperty Wr zr createPersonProfile setInternalOrTestUser Xr Or en opt_in_capturing opt_out_capturing has_opted_in_capturing has_opted_out_capturing get_explicit_consent_status is_capturing clear_opt_in_out_capturing Vr debug ki Gr getPageViewId captureTraceFeedback captureTraceMetric Nr".split(" "),n=0;n<o.length;