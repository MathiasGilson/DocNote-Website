      posthog.init('phc_x33HDW579g87nrPXvtCARteNbdnQyJ4R2DX475zHrdW9', {
        api_host: 'https://analytics.qualtir.com',
        defaults: '2026-01-30',
        person_profiles: 'always',
      });
    </script>

    <!-- Meta Pixel Code -->
    <script is:inline>
      !function(f,b,e,v,n,t,s)
      {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
      n.callMethod.apply(n,arguments):n.queue.push(arguments)};
      if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
      n.queue=[];t=b.createElement(e);t.async=!0;
      t.src=v;s=b.getElementsByTagName(e)[0];
      s.parentNode.insertBefore(t,s)}(window, document,'script',
      'https://connect.facebook.net/en_US/fbevents.js');
      fbq('init', '2210918162993748');
      fbq('track', 'PageView');
    </script>
    <noscript><img height="1" width="1" style="display:none"
      src="https://www.facebook.com/tr?id=2210918162993748&ev=PageView&noscript=1"
    /></noscript>
    <!-- End Meta Pixel Code -->
  </head>
  <body class="min-h-screen bg-gray-900 text-gray-900 antialiased">
    <Header locale={locale} translations={t.data} />
    <main class="relative z-10 bg-white lg:rounded-b-3xl lg:shadow-2xl">
      <slot />
    </main>
    <Footer locale={locale} translations={t.data} />
    <script>
      const footer = document.getElementById("site-footer")
      if (footer) {
        const isLg = () => window.matchMedia("(min-width: 1024px)").matches
        const updateMargin = () => {
          const main = document.querySelector("main")
          if (main) {
            main.style.marginBottom = isLg() ? `${footer.offsetHeight}px` : "0px"
          }
        }
        updateMargin()
        window.addEventListener("resize", updateMargin)
      }
    </script>
    <script>
      // PostHog conversion tracking for landing CTAs
      const ph = () => (window as any).posthog
      const locale = document.documentElement.lang || "en"
      ph()?.register?.({ site: "landing", locale })

      const ctaTarget = (href: string): string | null => {
        if (!href) return null
        if (href.includes("apps.apple.com")) return "app_store"
        if (href.includes("play.google.com")) return "play_store"
        if (href === "/app" || href.endsWith("/app") || href.includes("/app?") || href.includes("/app/")) return "webapp"
        return null
      }

      document.addEventListener("click", (e) => {
        const link = (e.target as HTMLElement)?.closest?.("a") as HTMLAnchorElement | null
        if (!link) return
        const target = ctaTarget(link.getAttribute("href") || "")
        if (!target) return
        ph()?.capture?.("cta_clicked", {
          target,
          href: link.href,
          text: (link.textContent || "").trim().slice(0, 80),
          path: location.pathname
        })
      })
    </script>
  </body>
</html>
