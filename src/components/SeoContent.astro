---
// Visually-hidden semantic content for SEO, AEO, GEO and LLMO.
// Rendered to the DOM (so crawlers and LLMs can read it) but invisible to
// sighted users. Uses .sr-only — Google explicitly accepts visually-hidden
// content as long as it is real, accessible, and not keyword spam.
//
// We render TWO variants — one for Switzerland (CH: Swiss hosting, FADP/nLPD,
// Swiss DRG, Art. 321 CP) and one for France/Rest of World (ROW: France HDS
// hosting, GDPR, PMSI, Art. 226-13). The ROW variant is shown by default;
// a small client script swaps to the CH variant if the visitor is detected
// as Swiss (timezone first, IP fallback). Both versions exist in the DOM,
// but the inactive one carries `hidden` so search engines see the active set.

interface Props {
  locale: 'en' | 'fr' | 'de';
}

const { locale } = Astro.props;

type Variant = {
  h2: string;
  paragraphs: string[];
};

