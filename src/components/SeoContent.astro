---

<section class="sr-only" aria-hidden="false" data-seo-content-row>
  <h2>{c.row.h2}</h2>
  {c.row.paragraphs.map((p) => <p>{p}</p>)}
</section>
<section class="sr-only" aria-hidden="false" data-seo-content-ch hidden>
  <h2>{c.ch.h2}</h2>
  {c.ch.paragraphs.map((p) => <p>{p}</p>)}
</section>

<script>
  import { detectUserCurrency } from '../utils/currency';

  (async () => {
    const currency = await detectUserCurrency();
    if (currency !== 'CHF') return;
    const row = document.querySelector<HTMLElement>('[data-seo-content-row]');
    const ch = document.querySelector<HTMLElement>('[data-seo-content-ch]');
    if (!row || !ch) return;
    row.hidden = true;
    ch.hidden = false;
  })();
</script>
