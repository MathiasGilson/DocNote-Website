---
interface Props {
  translations: any
}

const { translations: t } = Astro.props

const protocols = [
  t.compliance.protocolEncryption,
  t.compliance.protocolRetention,
  t.compliance.protocolRbac,
  t.compliance.protocolAudit,
]

const pillars = [
  {
    key: "swiss",
    title: t.compliance.swiss.title,
    description: t.compliance.swiss.description,
    mark: "Swiss Design",
    markSub: "Swiss Hosted",
  },
  {
    key: "hipaa",
    title: t.compliance.hipaa.title,
    description: t.compliance.hipaa.description,
    mark: "HIPAA",
    markSub: "Privacy",
  },
  {
    key: "iso",
    title: t.compliance.iso.title,
    description: t.compliance.iso.description,
    mark: "ISO",
    markSub: "27001",
  },
]
---

<section class="compliance-section py-20 lg:py-24" data-compliance>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-10 lg:mb-12 max-w-2xl">
      <span class="text-xs font-semibold text-violet-600 uppercase tracking-widest">{t.compliance.badge}</span>
      <h2 class="mt-3 text-2xl sm:text-3xl lg:text-4xl font-semibold text-gray-900 leading-snug tracking-tight">
        {t.compliance.title}
      </h2>
      <p class="mt-3 text-base text-gray-500 leading-relaxed">{t.compliance.subtitle}</p>
    </div>

    <div class="compliance-shell">
      <div class="grid lg:grid-cols-12 gap-0">
        <div class="lg:col-span-7 p-6 sm:p-8 lg:p-10">
          <h3 class="text-lg font-semibold text-gray-900 tracking-tight">{t.compliance.cardTitle}</h3>
          <p class="mt-2 text-sm text-gray-500 leading-relaxed max-w-xl">
            {t.compliance.cardDescription}
          </p>

          <div class="compliance-protocol mt-7">
            <div class="flex items-center gap-2.5 mb-4">
              <span class="compliance-lock" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
                </svg>
              </span>
              <span class="text-sm font-semibold text-gray-900">{t.compliance.protocolTitle}</span>
            </div>
            <ul class="space-y-3">
              {protocols.map((item) => (
                <li class="compliance-protocol-item">
                  <span class="compliance-check" aria-hidden="true">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                      <path d="M5 13l4 4L19 7"></path>
                    </svg>
                  </span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <div class="lg:col-span-5 compliance-marks p-6 sm:p-8 lg:p-10 flex flex-col justify-center gap-4 border-t lg:border-t-0 lg:border-l border-black/[0.06]">
          {pillars.map((pillar, i) => (
            <div class="compliance-mark" style={`--d:${0.08 + i * 0.1}s`} data-compliance-mark>
              <div class={`compliance-badge compliance-badge--${pillar.key}`} aria-hidden="true">
                <span class="compliance-badge-frame">
                  <span class="compliance-badge-main">{pillar.mark}</span>
                  <span class="compliance-badge-sub">{pillar.markSub}</span>
                </span>
              </div>
              <div class="min-w-0">
                <h4 class="text-sm font-semibold text-gray-900 tracking-tight">{pillar.title}</h4>
                <p class="mt-1 text-xs text-gray-500 leading-relaxed">{pillar.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const root = document.querySelector("[data-compliance]")
  if (root) {
    const marks = root.querySelectorAll("[data-compliance-mark]")
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            marks.forEach((mark) => mark.classList.add("is-visible"))
            observer.disconnect()
          }
        })
      },
      { threshold: 0.25 }
    )
    observer.observe(root)
  }
</script>

<style>
  .compliance-section {
    background:
      radial-gradient(ellipse 65% 45% at 8% 20%, rgba(121, 81, 251, 0.08), transparent 55%),
      linear-gradient(180deg, #ffffff 0%, #f7f5fc 55%, #ffffff 100%);
  }

  .compliance-shell {
    background: #fff;
    border: 1px solid rgba(15, 23, 42, 0.08);
    border-radius: 0.875rem;
    overflow: hidden;
    box-shadow:
      0 1px 2px rgba(15, 23, 42, 0.04),
      0 18px 40px rgba(15, 23, 42, 0.05);
    position: relative;
  }

  .compliance-protocol {
    background: #f8f8fa;
    border: 1px solid rgba(15, 23, 42, 0.06);
    border-radius: 0.75rem;
    padding: 1.15rem 1.2rem;
  }

  .compliance-lock {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 0.45rem;
    background: #1a1528;
    color: #cbb8ff;
  }

  .compliance-protocol-item {
    display: flex;
    align-items: flex-start;
    gap: 0.65rem;
    font-size: 0.8125rem;
    line-height: 1.45;
    color: #3f3f46;
  }

  .compliance-check {
    flex-shrink: 0;
    margin-top: 0.1rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.15rem;
    height: 1.15rem;
    border-radius: 999px;
    background: rgba(121, 81, 251, 0.12);
    color: #5b3fd4;
  }

  .compliance-marks {
    background: #f6f6f8;
  }

  .compliance-mark {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    padding: 0.85rem 0.9rem;
    border-radius: 0.75rem;
    background: #fff;
    border: 1px solid rgba(15, 23, 42, 0.07);
    opacity: 0;
    transform: translateY(10px);
    transition:
      opacity 0.55s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.55s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.25s ease,
      box-shadow 0.25s ease;
    transition-delay: var(--d, 0s);
  }

  .compliance-mark.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .compliance-mark:hover {
    border-color: #d4caf5;
    box-shadow: 0 8px 24px rgba(91, 63, 212, 0.08);
  }

  .compliance-badge {
    box-sizing: border-box;
    flex-shrink: 0;
    width: 5.5rem;
    height: 3.75rem;
    padding: 3px;
    border-radius: 0.7rem;
    background: linear-gradient(145deg, #9b6cff, #5b3fd4 55%, #7951fb);
    box-shadow: 0 4px 14px rgba(91, 63, 212, 0.18);
    display: flex;
    align-items: stretch;
  }

  .compliance-badge-frame {
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.2rem;
    flex: 1;
    min-height: 0;
    border-radius: 0.55rem;
    background: #faf8ff;
    border: 1px solid rgba(255, 255, 255, 0.65);
    padding: 0.25rem 0.35rem;
    text-align: center;
    line-height: 1.1;
  }

  .compliance-badge-main {
    display: block;
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.02em;
    color: #4c35c4;
  }

  .compliance-badge--swiss .compliance-badge-main {
    font-size: 0.58rem;
    letter-spacing: 0.01em;
  }

  .compliance-badge--hipaa .compliance-badge-main {
    font-size: 0.72rem;
    letter-spacing: 0.06em;
  }

  .compliance-badge-sub {
    display: block;
    margin: 0;
    font-size: 0.48rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #7c6bb5;
  }

  .compliance-badge--swiss .compliance-badge-sub {
    font-size: 0.48rem;
    letter-spacing: 0.02em;
  }

  @media (prefers-reduced-motion: reduce) {
    .compliance-mark {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>
