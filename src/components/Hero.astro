---
import { getLocaleFromUrl, getLocalizedPath } from "../utils/i18n"
import { DEMO_BOOKING_URL } from "../utils/links"

interface Props {
    translations: any
}

const { translations: t } = Astro.props
const locale = getLocaleFromUrl(Astro.url)

const stats = [
    {
        label: t.stats.timeSaved,
        target: 2,
        startFrom: 0,
        duration: 900,
        suffix: t.stats.timeSavedSuffix,
        easing: "linear",
        desc: t.stats.timeSavedDesc,
    },
    {
        label: t.stats.accuracy,
        target: 99,
        startFrom: 0,
        duration: 1200,
        suffix: "%",
        easing: "expo",
        desc: t.stats.accuracyDesc,
    },
    {
        label: t.stats.doctors,
        target: 1000,
        startFrom: 0,
        duration: 1600,
        suffix: "+",
        easing: "expo",
        desc: t.stats.doctorsDesc,
    },
]
---

<section class="hero-section relative pt-28 pb-16 lg:pt-36 lg:pb-24 overflow-hidden">
    <div class="absolute inset-0 z-0">
        <img
            src="/images/hero.jpeg"
            alt={locale === 'fr'
                ? 'Médecin en consultation utilisant DocNote pour la documentation clinique'
                : locale === 'de'
                  ? 'Ärztin in der Konsultation mit DocNote für klinische Dokumentation'
                  : 'Physician in consultation using DocNote for clinical documentation'}
            width="1200"
            height="880"
            fetchpriority="high"
            decoding="async"
            class="w-full h-full object-cover scale-105"
        />
        <div class="absolute inset-0 hero-veil"></div>
    </div>
    <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <p class="hero-eyebrow mb-5">{t.hero.badge}</p>

        <h1 class="hero-title text-4xl sm:text-5xl lg:text-[3.4rem] leading-[1.12] mb-5 tracking-tight">
            <span class="font-bold text-gray-900">{t.hero.title}</span>
            {
                t.hero.titleHighlight && (
                    <>
                        <br />
                        <span class="font-semibold text-gradient">{t.hero.titleHighlight}</span>
                    </>
                )
            }
        </h1>

        <p class="text-base sm:text-lg text-gray-600 mb-8 max-w-2xl mx-auto leading-relaxed">
            {t.hero.subtitle}
        </p>

        <div class="flex flex-col items-center gap-4 mb-8">
            <div class="flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-4">
                <a
                    href={getLocalizedPath("/tutorial", locale)}
                    class="inline-flex items-center justify-center px-7 py-3 text-base font-medium text-white bg-[#7951fb] hover:bg-[#5b3fd4] rounded-lg transition-colors shadow-lg shadow-violet-500/25"
                >
                    {t.hero.cta}
                </a>
                <a
                    href={DEMO_BOOKING_URL}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center justify-center px-7 py-3 text-base font-medium text-[#5b3fd4] bg-white/80 border border-[#7951fb]/40 hover:border-[#7951fb] hover:bg-white rounded-lg transition-colors"
                >
                    {t.contact.bookDemo}
                </a>
            </div>
            <a
                href={getLocalizedPath("/contact", locale)}
                class="hero-enterprise-link inline-flex items-center justify-center gap-1.5 text-base font-semibold text-[#5b3fd4] hover:text-[#4c35c4] transition-colors"
            >
                {t.hero.ctaSecondary}
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.25"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
            </a>
        </div>

        <div class="hero-founders inline-flex items-center gap-3 px-3 py-2 rounded-full bg-white/70 border border-violet-100 backdrop-blur-sm">
            <div class="flex -space-x-2">
                <img src="/images/dr_vincent_tan_sm.jpg" alt="Dr. Vincent Tan" width="36" height="36" class="w-9 h-9 rounded-full object-cover border-2 border-white" decoding="async" />
                <img src="/images/dre_alice_gilson_sm.jpg" alt="Dr. Alice Gilson" width="36" height="36" class="w-9 h-9 rounded-full object-cover border-2 border-white" decoding="async" />
            </div>
            <div class="text-left pr-1">
                <p class="text-sm font-semibold text-gray-900 leading-tight">{t.hero.founders}</p>
                <p class="text-xs text-gray-500 leading-tight">{t.hero.foundersRole}</p>
            </div>
        </div>
    </div>

    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 mt-14 lg:mt-20">
        <div class="relative">
            <!-- Desktop web app mockup -->
            <div
                class="hidden sm:block relative bg-white rounded-xl shadow-2xl shadow-violet-200/50 border border-violet-100/80 overflow-hidden"
            >
                <div class="bg-gray-50 border-b border-gray-200 px-3 py-2 flex items-center gap-2">
                    <div class="flex gap-1.5">
                        <div class="w-2.5 h-2.5 rounded-full bg-gray-300"></div>
                        <div class="w-2.5 h-2.5 rounded-full bg-gray-300"></div>
                        <div class="w-2.5 h-2.5 rounded-full bg-gray-300"></div>
                    </div>
                    <div class="flex-1 flex justify-center">
                        <div
                            class="bg-white rounded-md px-3 py-0.5 text-[10px] text-gray-400 border border-gray-200 max-w-[180px] w-full text-center"
                        >
                            docnote.care
                        </div>
                    </div>
                </div>

                <div class="flex min-h-[260px] sm:min-h-[420px]">
                    <div class="hidden sm:block w-36 bg-gray-50 border-r border-gray-200 p-3 flex-shrink-0">
                        <div class="flex items-center gap-1.5 mb-4">
                            <img src="/images/logo.png" alt="DocNote" class="w-5 h-5" />
                            <span class="text-[10px] font-semibold text-gray-900">DocNote</span>
                        </div>
                        <nav class="space-y-0.5">
                            <div
                                class="flex items-center gap-1.5 px-1.5 py-1 bg-gray-200 text-gray-700 rounded text-[10px]"
                            >
                                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                                    ></path></svg
                                >
                                {t.soapDemo.consultations}
                            </div>
                            <div class="flex items-center gap-1.5 px-1.5 py-1 text-gray-500 rounded text-[10px]">
                                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"
                                    ></path></svg
                                >
                                {t.soapDemo.patients}
                            </div>
                            <div class="flex items-center gap-1.5 px-1.5 py-1 text-gray-500 rounded text-[10px]">
                                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6z"
                                    ></path></svg
                                >
                                {t.soapDemo.templates}
                            </div>
                            <div class="flex items-center gap-1.5 px-1.5 py-1 text-gray-500 rounded text-[10px]">
                                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"
                                    ></path><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg
                                >
                                {t.soapDemo.settings}
                            </div>
                        </nav>
                    </div>

                    <div class="flex-1 p-3 sm:p-4">
                        <div class="flex items-center justify-between mb-3">
                            <div>
                                <h3 class="text-xs font-semibold text-gray-900">{t.soapDemo.consultationTitle}</h3>
                                <p class="text-[10px] text-gray-400 mt-0.5">{t.soapDemo.consultationDate}</p>
                            </div>
                            <div
                                id="recording-indicator"
                                class="flex items-center gap-1 px-2 py-0.5 bg-red-50 text-red-600 rounded-full text-[10px] font-medium opacity-0"
                            >
                                <span class="w-1.5 h-1.5 bg-red-500 rounded-full animate-pulse"></span>
                                {t.soapDemo.recording}
                            </div>
                        </div>

                        <div id="soap-note-container" class="bg-gray-50 rounded-md p-3 border border-gray-100">
                            <div
                                id="soap-title"
                                class="text-[10px] font-semibold text-gray-400 uppercase tracking-wider mb-2 opacity-0"
                            >
                                {t.soapDemo.soapNoteGenerated}
                            </div>
                            <div class="space-y-2">
                                <div id="soap-s" class="flex items-baseline gap-1.5 opacity-0">
                                    <span class="text-[10px] font-bold text-gray-900 flex-shrink-0">S:</span>
                                    <span class="text-[10px] text-gray-600 leading-relaxed soap-text"></span>
                                </div>
                                <div id="soap-o" class="flex items-baseline gap-1.5 opacity-0">
                                    <span class="text-[10px] font-bold text-gray-900 flex-shrink-0">O:</span>
                                    <span class="text-[10px] text-gray-600 leading-relaxed soap-text"></span>
                                </div>
                                <div id="soap-a" class="flex items-baseline gap-1.5 opacity-0">
                                    <span class="text-[10px] font-bold text-gray-900 flex-shrink-0">A:</span>
                                    <span class="text-[10px] text-gray-600 leading-relaxed soap-text"></span>
                                </div>
                                <div id="soap-p" class="flex items-baseline gap-1.5 opacity-0">
                                    <span class="text-[10px] font-bold text-gray-900 flex-shrink-0">P:</span>
                                    <span class="text-[10px] text-gray-600 leading-relaxed soap-text"></span>
                                </div>
                            </div>
                        </div>

                        <div id="saved-status" class="flex items-center justify-between mt-2 opacity-0">
                            <span class="text-green-600 font-medium flex items-center gap-1 text-[10px]">
                                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M5 13l4 4L19 7"></path>
                                </svg>
                                {t.soapDemo.savedToEHR}
                            </span>
                            <span class="text-gray-400 text-[10px]">{t.soapDemo.justNow}</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Mobile app window -->
            <div
                id="phone-mockup"
                class="block sm:absolute sm:-bottom-8 sm:-right-6 lg:-right-12 z-10 opacity-0 mx-auto"
                style="width:300px;aspect-ratio:9/16;"
            >
                <div
                    class="bg-white rounded-[40px] py-4 px-2 border border-gray-200/80 shadow-2xl shadow-indigo-200/40 overflow-hidden w-full h-full flex flex-col"
                >
                    <!-- Status bar -->
                    <div class="flex items-center justify-between px-4 pt-1 pb-1">
                        <span class="text-[11px] font-semibold text-gray-600">14:30</span>
                        <div class="flex items-center">
                            <!-- Cellular -->
                            <svg class="w-4 h-2 text-gray-600" viewBox="0 0 18 12" fill="currentColor">
                                <rect x="0" y="9" width="3" height="3" rx="0.5"></rect>
                                <rect x="4" y="6" width="3" height="6" rx="0.5"></rect>
                                <rect x="8" y="3" width="3" height="9" rx="0.5"></rect>
                                <rect x="12" y="0" width="3" height="12" rx="0.5"></rect>
                            </svg>
                            <!-- Battery -->
                            <svg class="w-6 h-2 text-gray-600" viewBox="0 0 27 13" fill="currentColor">
                                <rect
                                    x="0"
                                    y="0.5"
                                    width="22"
                                    height="12"
                                    rx="2.5"
                                    stroke="currentColor"
                                    stroke-width="1"
                                    fill="none"></rect>
                                <rect x="1.5" y="2" width="19" height="9" rx="1.5"></rect>
                                <path d="M23.5 4.5v4a2 2 0 000-4z"></path>
                            </svg>
                        </div>
                    </div>

                    <!-- Content -->
                    <div class="flex-1 p-4 flex flex-col">
                        <p class="text-[12px] text-gray-500 mb-0.5">{t.soapDemo.patientId}</p>
                        <p class="text-sm font-semibold text-gray-900 mb-3">{t.soapDemo.generalPractice}</p>

                        <!-- Recording status -->
                        <div id="phone-recording-status" class="opacity-0">
                            <div class="bg-red-50 rounded-lg p-2.5 mb-2.5">
                                <div class="flex items-center justify-between mb-2">
                                    <div class="flex items-center gap-1.5">
                                        <span class="w-2 h-2 bg-red-500 rounded-full animate-pulse"></span>
                                        <span class="text-[12px] text-red-600 font-medium">{t.soapDemo.recording}</span>
                                    </div>
                                    <span id="phone-timer" class="text-[12px] text-red-500 font-mono">0:00</span>
                                </div>
                                <div class="flex items-center justify-center gap-[3px] h-6">
                                    <div
                                        class="w-[2px] bg-red-300 rounded-full animate-waveform"
                                        style="height:8px;animation-delay:0s"
                                    >
                                    </div>
                                    <div
                                        class="w-[2px] bg-red-400 rounded-full animate-waveform"
                                        style="height:12px;animation-delay:0.1s"
                                    >
                                    </div>
                                    <div
                                        class="w-[2px] bg-red-500 rounded-full animate-waveform"
                                        style="height:16px;animation-delay:0.2s"
                                    >
                                    </div>
                                    <div
                                        class="w-[2px] bg-red-400 rounded-full animate-waveform"
                                        style="height:10px;animation-delay:0.3s"
                                    >
                                    </div>
                                    <div
                                        class="w-[2px] bg-red-500 rounded-full animate-waveform"
                                        style="height:18px;animation-delay:0.15s"
                                    >
                                    </div>
                                    <div
                                        class="w-[2px] bg-red-400 rounded-full animate-waveform"
                                        style="height:12px;animation-delay:0.25s"
                                    >
                                    </div>
                                    <div
                                        class="w-[2px] bg-red-300 rounded-full animate-waveform"
                                        style="height:8px;animation-delay:0.35s"
                                    >
                                    </div>
                                    <div
                                        class="w-[2px] bg-red-400 rounded-full animate-waveform"
                                        style="height:14px;animation-delay:0.05s"
                                    >
                                    </div>
                                    <div
                                        class="w-[2px] bg-red-500 rounded-full animate-waveform"
                                        style="height:18px;animation-delay:0.2s"
                                    >
                                    </div>
                                    <div
                                        class="w-[2px] bg-red-400 rounded-full animate-waveform"
                                        style="height:10px;animation-delay:0.3s"
                                    >
                                    </div>
                                    <div
                                        class="w-[2px] bg-red-300 rounded-full animate-waveform"
                                        style="height:8px;animation-delay:0.4s"
                                    >
                                    </div>
                                    <div
                                        class="w-[2px] bg-red-400 rounded-full animate-waveform"
                                        style="height:12px;animation-delay:0.1s"
                                    >
                                    </div>
                                    <div
                                        class="w-[2px] bg-red-500 rounded-full animate-waveform"
                                        style="height:16px;animation-delay:0.25s"
                                    >
                                    </div>
                                    <div
                                        class="w-[2px] bg-red-400 rounded-full animate-waveform"
                                        style="height:10px;animation-delay:0.35s"
                                    >
                                    </div>
                                    <div
                                        class="w-[2px] bg-red-300 rounded-full animate-waveform"
                                        style="height:8px;animation-delay:0.45s"
                                    >
                                    </div>
                                    <div
                                        class="w-[2px] bg-red-400 rounded-full animate-waveform"
                                        style="height:14px;animation-delay:0.15s"
                                    >
                                    </div>
                                    <div
                                        class="w-[2px] bg-red-500 rounded-full animate-waveform"
                                        style="height:12px;animation-delay:0.05s"
                                    >
                                    </div>
                                </div>
                            </div>

                            <div id="phone-transcript" class="opacity-0">
                                <p class="text-[9px] text-gray-400 uppercase tracking-wider mb-1">{t.soapDemo.liveTranscript}</p>
                                <div class="space-y-1">
                                    <div class="h-1.5 bg-gray-100 rounded-full w-full"></div>
                                    <div class="h-1.5 bg-gray-100 rounded-full w-4/5"></div>
                                    <div class="h-1.5 bg-gray-100 rounded-full w-3/5"></div>
                                </div>
                            </div>
                        </div>

                        <!-- SOAP report on phone -->
                        <div id="phone-done" class="opacity-0 hidden">
                            <div class="text-[9px] font-semibold text-gray-400 uppercase tracking-wider mb-1.5">
                                {t.soapDemo.soapNote}
                            </div>
                            <div class="bg-gray-50 rounded-lg p-2 border border-gray-100 space-y-1.5">
                                <div id="phone-soap-s" class="flex items-baseline gap-1 opacity-0">
                                    <span class="text-[12px] font-bold text-gray-900 flex-shrink-0">S:</span>
                                    <span class="text-[12px] text-gray-600 leading-relaxed phone-soap-text"></span>
                                </div>
                                <div id="phone-soap-o" class="flex items-baseline gap-1 opacity-0">
                                    <span class="text-[12px] font-bold text-gray-900 flex-shrink-0">O:</span>
                                    <span class="text-[12px] text-gray-600 leading-relaxed phone-soap-text"></span>
                                </div>
                                <div id="phone-soap-a" class="flex items-baseline gap-1 opacity-0">
                                    <span class="text-[12px] font-bold text-gray-900 flex-shrink-0">A:</span>
                                    <span class="text-[12px] text-gray-600 leading-relaxed phone-soap-text"></span>
                                </div>
                                <div id="phone-soap-p" class="flex items-baseline gap-1 opacity-0">
                                    <span class="text-[12px] font-bold text-gray-900 flex-shrink-0">P:</span>
                                    <span class="text-[12px] text-gray-600 leading-relaxed phone-soap-text"></span>
                                </div>
                            </div>
                            <div id="phone-saved" class="flex items-center gap-1 mt-1.5 opacity-0">
                                <svg
                                    class="w-2.5 h-2.5 text-green-500"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M5 13l4 4L19 7"></path>
                                </svg>
                                <span class="text-[12px] text-green-600 font-medium">{t.soapDemo.savedToEHR}</span>
                            </div>
                        </div>

                        <div class="flex-1"></div>
                    </div>

                    <!-- Mic button -->
                    <div class="px-4 pb-4 pt-1 flex-shrink-0">
                        <div
                            id="phone-mic-btn"
                            class="w-12 h-12 bg-gradient-to-br from-violet-500 to-indigo-500 rounded-full flex items-center justify-center mx-auto shadow-lg shadow-indigo-500/30 opacity-0"
                        >
                            <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"
                                ></path></svg
                            >
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 mt-20 lg:mt-28">
        <div class="hero-stats grid md:grid-cols-3 gap-px bg-violet-200/50 rounded-2xl overflow-hidden border border-violet-100/80 shadow-lg shadow-violet-500/10">
            {
                stats.map((stat, index) => (
                    <div
                        class="stat-card bg-white/85 backdrop-blur-sm px-8 py-9 text-center"
                        data-target={stat.target}
                        data-start-from={stat.startFrom}
                        data-duration={stat.duration ?? 1400}
                        data-easing={stat.easing}
                        data-suffix={stat.suffix}
                        data-delay={index * 140}
                    >
                        <p class="text-xs font-semibold uppercase tracking-[0.14em] text-[#5b3fd4] mb-3">{stat.label}</p>
                        <p class="stat-number text-5xl sm:text-[3.25rem] font-bold tracking-tight leading-none mb-2">
                            <span class="stat-value text-gradient">0</span><span class="stat-suffix text-gradient">{stat.suffix}</span>
                        </p>
                        <p class="text-sm text-gray-500">{stat.desc}</p>
                    </div>
                ))
            }
        </div>
    </div>
</section>

<div id="video-modal" class="fixed inset-0 z-50 hidden">
    <div id="modal-overlay" class="absolute inset-0 bg-black/80 backdrop-blur-sm flex items-center justify-center p-4">
        <div id="modal-content" class="relative w-full max-w-4xl bg-black rounded-2xl overflow-hidden shadow-2xl">
            <button
                id="close-modal-btn"
                type="button"
                class="absolute -top-12 right-0 text-white/80 hover:text-white transition-colors"
                aria-label="Close modal"
            >
                <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"
                    ></path>
                </svg>
            </button>
