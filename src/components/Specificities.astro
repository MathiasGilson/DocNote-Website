---
interface Props {
  translations: any;
}

const { translations: t } = Astro.props;

const cards = [
  {
    key: 'coding',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />`,
    gradient: 'from-blue-500 to-indigo-600',
  },
  {
    key: 'tardoc',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />`,
    gradient: 'from-emerald-500 to-teal-600',
  },
  {
    key: 'ehr',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" />`,
    gradient: 'from-amber-500 to-orange-600',
  },
  {
    key: 'templates',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" />`,
    gradient: 'from-violet-500 to-purple-600',
  },
  {
    key: 'context',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13" />`,
    gradient: 'from-pink-500 to-rose-600',
  },
  {
    key: 'hospital',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />`,
    gradient: 'from-cyan-500 to-sky-600',
  },
  {
    key: 'sync',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />`,
    gradient: 'from-fuchsia-500 to-pink-600',
  },
  {
    key: 'dayHospital',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />`,
    gradient: 'from-indigo-500 to-blue-600',
  },
];
---

<section class="py-20 bg-gradient-to-b from-white via-violet-50/30 to-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-4">
      <span class="text-xs font-medium text-gray-400 uppercase tracking-widest">{t.specificities.badge}</span>
    </div>
    <div class="text-center mb-14">
      <h2 class="text-2xl sm:text-3xl lg:text-4xl font-semibold text-gray-900 max-w-3xl mx-auto leading-snug">
        {t.specificities.title}
      </h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      {cards.map((card) => (
        <div class="spec-card group" data-key={card.key}>
          <div class="spec-card-inner">
            <!-- Front face -->
            <div class="spec-card-face spec-card-front bg-white border border-gray-200 rounded-2xl p-6 shadow-sm flex flex-col items-center justify-center text-center">
              <div class={`w-14 h-14 rounded-2xl bg-gradient-to-br ${card.gradient} flex items-center justify-center mb-5 shadow-md`}>
                <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" set:html={card.icon} />
              </div>
              <h3 class="text-base font-semibold text-gray-900 leading-snug tracking-tight">
                {t.specificities[card.key].title}
              </h3>
            </div>
            <!-- Back face -->
            <div class={`spec-card-face spec-card-back bg-gradient-to-br ${card.gradient} rounded-2xl px-5 py-5 shadow-lg flex flex-col text-white overflow-auto`}>
              <h3 class="text-sm font-semibold mb-2.5 tracking-tight">
                {t.specificities[card.key].title}
              </h3>
              {card.key === 'coding' ? (
                <p
                  class="text-[0.8125rem] leading-[1.55] text-white/95 text-justify"
                  data-coding-description
                  data-description-ch={t.specificities.coding.descriptionCh}
                  data-description-row={t.specificities.coding.descriptionRow}
                >
                  {t.specificities.coding.descriptionRow}
                </p>
              ) : (
                <p class="text-[0.8125rem] leading-[1.55] text-white/95 text-justify">
                  {t.specificities[card.key].description}
                </p>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .spec-card {
    perspective: 1200px;
    min-height: 280px;
  }
  .spec-card-inner {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 280px;
    transition: transform 0.7s cubic-bezier(0.4, 0, 0.2, 1);
    transform-style: preserve-3d;
  }
  .spec-card:hover .spec-card-inner,
  .spec-card:focus-within .spec-card-inner {
    transform: rotateY(180deg);
  }
  .spec-card-face {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
  }
  .spec-card-back {
    transform: rotateY(180deg);
  }
</style>

<script>
  import { detectUserCurrency } from '../utils/currency';

  (async () => {
    const el = document.querySelector<HTMLElement>('[data-coding-description]');
    if (!el) return;
    const currency = await detectUserCurrency();
    const ch = el.dataset.descriptionCh || '';
    const row = el.dataset.descriptionRow || '';
    el.textContent = currency === 'CHF' ? ch : row;
  })();
</script>
