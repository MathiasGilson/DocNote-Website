---
interface Props {
  translations: any;
}

const { translations: t } = Astro.props;

const cards = [
  {
    key: 'coding',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />`,
    gradient: 'from-blue-500 to-indigo-600',
  },
  {
    key: 'tardoc',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />`,
    gradient: 'from-emerald-500 to-teal-600',
  },
  {
    key: 'ehr',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" />`,
    gradient: 'from-amber-500 to-orange-600',
  },
  {
    key: 'templates',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" />`,
    gradient: 'from-violet-500 to-purple-600',
  },
  {
    key: 'context',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13" />`,
    gradient: 'from-pink-500 to-rose-600',
  },
  {
    key: 'hospital',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />`,
    gradient: 'from-cyan-500 to-sky-600',
  },
  {
    key: 'sync',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />`,
    gradient: 'from-fuchsia-500 to-pink-600',
  },
];
---

<section class="py-20 bg-gradient-to-b from-white via-violet-50/30 to-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-4">
      <span class="text-xs font-medium text-gray-400 uppercase tracking-widest">{t.specificities.badge}</span>
    </div>
    <div class="text-center mb-6">
      <h2 class="text-2xl sm:text-3xl lg:text-4xl font-semibold text-gray-900 max-w-3xl mx-auto leading-snug">
        {t.specificities.title}
      </h2>
    </div>
    <div class="text-center mb-14">
      <p class="text-gray-500 max-w-2xl mx-auto">
        {t.specificities.subtitle}
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      {cards.map((card) => (
        <div class="spec-card group" data-key={card.key}>
          <div class="spec-card-inner">
            <!-- Front face -->
            <div class="spec-card-face spec-card-front bg-white border border-gray-200 rounded-2xl p-6 shadow-sm hover:shadow-lg transition-shadow flex flex-col">
              <div class={`w-12 h-12 rounded-xl bg-gradient-to-br ${card.gradient} flex items-center justify-center mb-4 shadow-md`}>
                <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" set:html={card.icon} />
              </div>
              <h3 class="text-lg font-semibold text-gray-900 mb-2">
                {t.specificities[card.key].title}
              </h3>
              <p class="text-sm text-gray-500 leading-relaxed flex-grow">
                {t.specificities[card.key].teaser}
              </p>
              <div class="mt-4 flex items-center gap-1.5 text-xs font-medium text-violet-600">
                <span>{t.specificities.clickToFlip}</span>
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                </svg>
              </div>
            </div>
            <!-- Back face -->
            <div class={`spec-card-face spec-card-back bg-gradient-to-br ${card.gradient} rounded-2xl p-6 shadow-lg flex flex-col text-white`}>
              <h3 class="text-lg font-semibold mb-3">
                {t.specificities[card.key].title}
              </h3>
              <p class="text-sm leading-relaxed flex-grow text-white/95">
                {t.specificities[card.key].description}
              </p>
              <div class="mt-4 flex items-center gap-1.5 text-xs font-medium text-white/90">
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                </svg>
                <span>{t.specificities.clickToFlipBack}</span>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .spec-card {
    perspective: 1200px;
    min-height: 260px;
    cursor: pointer;
  }
  .spec-card-inner {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 260px;
    transition: transform 0.7s cubic-bezier(0.4, 0, 0.2, 1);
    transform-style: preserve-3d;
  }
  .spec-card.is-flipped .spec-card-inner {
    transform: rotateY(180deg);
  }
  .spec-card-face {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
  }
  .spec-card-back {
    transform: rotateY(180deg);
  }
</style>

<script>
  const cards = document.querySelectorAll('.spec-card');
  cards.forEach((card) => {
    card.addEventListener('click', () => {
      card.classList.toggle('is-flipped');
    });
  });
</script>
